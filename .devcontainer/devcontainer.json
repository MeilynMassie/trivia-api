{
  "name": "Spring Boot",
  "image": "mcr.microsoft.com/devcontainers/java:21",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-spring-boot"
      ]
    }
  },
  "remoteEnv": {
    "DB_URL": "${secrets.DB_URL}",
    "DB_USER": "${secrets.DB_USER}",
    "DB_PASSWORD": "${secrets.DB_PASSWORD}"
  }
}